<view class="container">

  <!-- Tabs -->
  <view class="tabs">
    <view class="tab-item {{activeTab===0?'tab-active':''}}" bindtap="onTabTap" data-idx="0">日历视图</view>
    <view class="tab-item {{activeTab===1?'tab-active':''}}" bindtap="onTabTap" data-idx="1">分类视图</view>
  </view>

  <!-- Calendar View -->
  <view wx:if="{{activeTab===0}}" class="calendar-view">
    <view class="cal-header">
      <text class="cal-month">{{currentMonth}}</text>
    </view>
    <view class="cal-weekdays">
      <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="weekday">{{item}}</text>
    </view>
    <view class="cal-grid">
      <view wx:for="{{calendarDays}}" wx:key="index" class="cal-day {{item.today?'cal-today':''}} {{item.active?'cal-active':''}}">
        <text>{{item.day}}</text>
        <view wx:if="{{item.active}}" class="cal-dot"></view>
      </view>
    </view>
    <!-- Upcoming events -->
    <view class="section-title">近期活动</view>
    <view class="act-list">
      <view class="act-card card" wx:for="{{contents}}" wx:key="id" bindtap="onContentTap" data-id="{{item.id}}">
        <view class="act-cover" style="background:linear-gradient(135deg,{{item.color}},#1a1a1a)"></view>
        <view class="act-info">
          <text class="act-title">{{item.title}}</text>
          <text class="act-time">{{item.time}}</text>
          <text class="act-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Category View -->
  <view wx:if="{{activeTab===1}}" class="cat-view">
    <view wx:for="{{categories}}" wx:key="*this" class="cat-section">
      <view class="section-title">{{item}}</view>
      <view class="act-list">
        <block wx:for="{{contents}}" wx:key="id" wx:for-item="c">
          <view wx:if="{{c.category===item}}" class="act-card card" bindtap="onContentTap" data-id="{{c.id}}">
            <view class="act-cover" style="background:linear-gradient(135deg,{{c.color}},#1a1a1a)"></view>
            <view class="act-info">
              <text class="act-title">{{c.title}}</text>
              <text class="act-time">{{c.time}}</text>
              <text class="act-desc">{{c.desc}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

</view>
