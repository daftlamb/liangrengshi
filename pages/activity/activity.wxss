.tabs {
  display: flex;
  border-bottom: 1rpx solid #e8e0d0;
  padding: 0 32rpx;
  background: #f5f0e8;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 26rpx;
  color: #888888;
}
.tab-active {
  color: #5a7a4a;
  border-bottom: 2rpx solid #5a7a4a;
}

.cal-header { padding: 32rpx 32rpx 16rpx; }
.cal-month { font-size: 30rpx; color: #1a1a1a; font-weight: 300; }

.cal-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  padding: 0 16rpx;
}
.weekday {
  text-align: center;
  font-size: 22rpx;
  color: #aaaaaa;
  padding: 12rpx 0;
}

.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  padding: 0 16rpx 24rpx;
  gap: 4rpx;
}
.cal-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #888888;
  position: relative;
}
.cal-today { color: #1a1a1a; font-weight: 500; }
.cal-active { color: #5a7a4a; }
.cal-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #5a7a4a;
  margin-top: 4rpx;
}

.act-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 32rpx;
}
.act-card {
  display: flex;
  flex-direction: row;
  overflow: hidden;
  height: 160rpx;
}
.act-cover {
  width: 200rpx;
  height: 160rpx;
  flex-shrink: 0;
}
.act-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  justify-content: center;
}
.act-title { font-size: 28rpx; color: #1a1a1a; font-weight: 400; }
.act-time  { font-size: 22rpx; color: #8b6914; }
.act-desc  { font-size: 22rpx; color: #888888; line-height: 1.4; }

.cat-section { margin-bottom: 8rpx; }
.cat-view { padding-bottom: 120rpx; }
.calendar-view { padding-bottom: 120rpx; }

.act-cover { position: relative; overflow: hidden; }

.act-cover-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}
