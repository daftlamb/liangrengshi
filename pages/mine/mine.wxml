<view class="container">

  <!-- User Info -->
  <view class="user-header">
    <view class="avatar-wrap">
      <view class="avatar-placeholder">M</view>
    </view>
    <view class="user-info">
      <text class="user-name">良壤访客</text>
      <text class="user-sub">打卡 {{checkinCount}} 次</text>
    </view>
  </view>

  <!-- Achievement Levels -->
  <view class="achievement-section card">
    <text class="ach-title">打卡成就</text>
    <view class="ach-levels">
      <view
        wx:for="{{achievementLevels}}" wx:key="*this"
        class="ach-item {{index <= currentLevel ? 'ach-unlocked' : ''}}"
      >
        <view class="ach-circle">{{item}}</view>
        <text class="ach-label">Lv.{{index+1}}</text>
      </view>
    </view>
  </view>

  <!-- Menu -->
  <view class="menu-list">
    <view
      class="menu-item"
      wx:for="{{menuItems}}" wx:key="id"
      bindtap="onMenuTap" data-label="{{item.label}}"
    >
      <image class="menu-icon" src="{{item.icon}}" mode="aspectFit"></image>
      <text class="menu-label">{{item.label}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

</view>
