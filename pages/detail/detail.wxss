.detail-cover {
  width: 100%;
  height: 500rpx;
  display: flex;
  align-items: flex-end;
  padding: 40rpx;
  box-sizing: border-box;
}
.detail-kv-text { display: flex; flex-direction: column; gap: 16rpx; }
.detail-kv-title { font-size: 44rpx; font-weight: 300; color: #fff; letter-spacing: 2rpx; }

.detail-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #222;
}
.meta-time { font-size: 24rpx; color: #888; }
.meta-cat {
  font-size: 22rpx;
  color: #e8d5a3;
  border: 1rpx solid rgba(232,213,163,0.4);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.detail-body { padding: 32rpx; }
.detail-text { font-size: 28rpx; color: #cccccc; line-height: 1.8; white-space: pre-wrap; }

.detail-actions {
  display: flex;
  gap: 16rpx;
  padding: 32rpx;
  padding-bottom: 60rpx;
}
.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
}
.btn-outline { border: 1rpx solid #333; color: #aaa; }
.btn-primary { background: #e8d5a3; color: #0a0a0a; font-weight: 500; }
