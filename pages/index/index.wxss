/* index.wxss */

.kv-swiper {
  width: 100%;
  height: 420rpx;
}
.kv-item {
  width: 100%;
  height: 420rpx;
  display: flex;
  align-items: flex-end;
}
.kv-content {
  padding: 40rpx;
}
.kv-title {
  display: block;
  font-size: 40rpx;
  font-weight: 300;
  color: #ffffff;
  letter-spacing: 2rpx;
}
.kv-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 8rpx;
}

/* Quick grid */
.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  padding: 32rpx 24rpx;
  gap: 0;
}
.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
}
.quick-icon { width: 44rpx; height: 44rpx; }
.quick-label { font-size: 22rpx; color: #666666; }

/* Category tabs */
.cat-scroll {
  white-space: nowrap;
  padding: 0 24rpx 16rpx;
}
.cat-list {
  display: inline-flex;
  gap: 16rpx;
}
.cat-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #888888;
  background: #ede8dc;
  white-space: nowrap;
}
.cat-active {
  color: #ffffff;
  background: #5a7a4a;
}

/* Feed */
.feed {
  padding: 8rpx 24rpx 120rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.feed-card { overflow: hidden; }
.feed-cover {
  width: 100%;
  height: 320rpx;
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 20rpx;
  box-sizing: border-box;
}
.feed-info {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.feed-title {
  font-size: 30rpx;
  font-weight: 400;
  color: #1a1a1a;
}
.feed-desc {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.5;
}
.feed-time {
  font-size: 22rpx;
  color: #aaaaaa;
}
