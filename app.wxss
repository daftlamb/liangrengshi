page {
  background-color: #0a0a0a;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-weight: 300;
}

.container {
  min-height: 100vh;
  background-color: #0a0a0a;
}

/* Cards */
.card {
  background: #1a1a1a;
  border-radius: 12rpx;
  overflow: hidden;
}

/* Tags */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 400;
}
.tag-active { background: rgba(232,213,163,0.15); color: #e8d5a3; }
.tag-new    { background: rgba(255,255,255,0.1);  color: #ffffff; }
.tag-rec    { background: rgba(100,200,100,0.15); color: #7ecb7e; }
.tag-soon   { background: rgba(150,150,255,0.15); color: #a0a0ff; }

/* Section title */
.section-title {
  font-size: 28rpx;
  color: #999999;
  letter-spacing: 2rpx;
  padding: 32rpx 32rpx 16rpx;
}

/* Divider */
.divider {
  height: 1rpx;
  background: #222222;
  margin: 0 32rpx;
}
