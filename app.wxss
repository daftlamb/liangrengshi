page {
  background-color: #f5f0e8;
  color: #1a1a1a;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-weight: 300;
}

.container {
  min-height: 100vh;
  background-color: #f5f0e8;
}

/* Cards */
.card {
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
}

/* Tags */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 400;
}
.tag-active { background: rgba(139,105,20,0.12); color: #8b6914; }
.tag-new    { background: rgba(90,122,74,0.12);  color: #5a7a4a; }
.tag-rec    { background: rgba(90,122,74,0.15);  color: #3d6030; }
.tag-soon   { background: rgba(100,100,180,0.12); color: #5555aa; }

/* Section title */
.section-title {
  font-size: 28rpx;
  color: #888888;
  letter-spacing: 2rpx;
  padding: 32rpx 32rpx 16rpx;
}

/* Divider */
.divider {
  height: 1rpx;
  background: #e8e0d0;
  margin: 0 32rpx;
}
